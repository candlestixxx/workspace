# ===========================================
# BROBOCALLZ CONFIGURATION
# Copy this to .env and fill in your values
# ===========================================

# Twilio Credentials (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# SendGrid for email transcripts (get from https://sendgrid.com)
SENDGRID_API_KEY=SG.your-sendgrid-key-here
NOTIFICATION_EMAIL=owner@business.com

# Server Configuration
PORT=3000
BASE_URL=https://your-ngrok-or-domain.com

# Business Configuration (customize per client)
BUSINESS_NAME=Cliff's Small Engine Repair
BUSINESS_GREETING=Hi, thanks for calling Cliff's Small Engine Repair. How can I help you today?
BUSINESS_CONTEXT=You are a helpful receptionist for a small engine repair shop. We fix lawnmowers, chainsaws, generators, and other small engines. We offer pickup and delivery. Hours are Monday through Saturday 8am to 6pm.
