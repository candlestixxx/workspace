# ===========================================
# BROBOCALLZ CONFIGURATION
# Copy this to .env and fill in your values
# ===========================================

# Twilio Credentials (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-key-here

# SendGrid for email transcripts (get from https://sendgrid.com)
SENDGRID_API_KEY=SG.your-sendgrid-key-here
NOTIFICATION_EMAIL=owner@business.com
FROM_EMAIL=brobocallz@yourdomain.com

# Server Configuration
PORT=3000
BASE_URL=https://your-ngrok-or-domain.com

# Business Configuration (customize per client)
BUSINESS_NAME=Cliff's Small Engine Repair
BUSINESS_GREETING=Hi, thanks for calling Cliff's Small Engine Repair! How can I help you today?
BUSINESS_CONTEXT=You are a friendly receptionist for a small engine repair shop. We fix lawnmowers, chainsaws, weed eaters, generators, and other small engines. We offer pickup and delivery within 20 miles. Hours are Monday through Saturday 8am to 6pm. Typical turnaround is 2-3 days. We provide free estimates.

# Call Recording Configuration
# NOTE: To enable recording, set RECORD_CALLS=true AND enable recording in Twilio Console:
# 1. Go to Twilio Console -> Voice -> Settings -> Recording
# 2. Enable "Record incoming calls" and/or "Record outgoing calls"
# 3. Choose recording format (mp3 recommended)
RECORD_CALLS=true
RECORDING_STORAGE_DIR=./recordings
RECORDING_RETENTION_DAYS=30
RECORDING_FORMAT=wav

# Knowledge Base / RAG Configuration
# Pinecone for vector database (get from https://app.pinecone.io)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=knowledge-base
PINECONE_REGION=us-east-1

# Enable/disable knowledge base features
KNOWLEDGE_BASE_ENABLED=true

# Document storage directory (for uploaded PDFs, Word docs, etc.)
DOCUMENT_STORAGE_DIR=./documents
KNOWLEDGE_BASE_DIR=./knowledge-base

# Embedding model (use text-embedding-3-small for best performance/cost ratio)
EMBEDDING_MODEL=text-embedding-3-small
